{
  "name": "@otto-build/contracts",
  "version": "1.0.8",
  "description": "Shared public contracts for OTTO workspace boundaries",
  "license": "MIT",
  "otto": {
    "linkable": true,
    "scope": "@otto-build",
    "name": "contracts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmetech/otto-cli.git",
    "directory": "packages/contracts"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --incremental false",
    "test": "node --test dist/rpc.test.js"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}

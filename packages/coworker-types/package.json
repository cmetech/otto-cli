{
  "name": "@otto/coworker-types",
  "version": "0.0.1",
  "description": "Shared types and contracts for Otto co-worker packages",
  "type": "module",
  "otto": {
    "linkable": true,
    "scope": "@otto",
    "name": "coworker-types"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:publish": "tsc -p tsconfig.publish.json"
  },
  "files": ["dist"]
}

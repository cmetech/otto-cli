{
  "name": "@otto-build/mcp-server",
  "version": "1.3.1",
  "description": "MCP server exposing OTTO orchestration tools for compatible clients",
  "license": "MIT",
  "otto": {
    "linkable": true,
    "scope": "@otto-build",
    "name": "mcp-server"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmetech/otto-cli.git",
    "directory": "packages/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "otto-mcp-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test dist/mcp-server.test.js dist/remote-questions.test.js"
  },
  "dependencies": {
    "@otto-build/contracts": "^1.3.1",
    "@otto-build/rpc-client": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ]
}

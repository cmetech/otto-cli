{
  "name": "@otto-build/rpc-client",
  "version": "1.2.0",
  "description": "Standalone RPC client SDK for OTTO — zero internal dependencies",
  "license": "MIT",
  "otto": {
    "linkable": true,
    "scope": "@otto-build",
    "name": "rpc-client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmetech/otto-cli.git",
    "directory": "packages/rpc-client"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/rpc-client.test.js"
  },
  "dependencies": {
    "@otto-build/contracts": "^1.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}

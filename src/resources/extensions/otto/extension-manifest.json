{
  "id": "otto",
  "name": "OTTO",
  "version": "0.3.0",
  "description": "OTTO-specific services — gateway probe, LangFlow control plane, LangFlow flow triggers, LangFlow flow builder, prompt engineer",
  "tier": "core",
  "requires": { "platform": ">=2.29.0" },
  "provides": {
    "hooks": ["session_start"],
    "tools": [
      "otto__refresh_catalog",
      "otto__normalize_catalog",
      "otto__check_catalog_health",
      "otto__inspect_component",
      "otto__validate_flow",
      "otto__import_flow",
      "otto__smoke_test_flow"
    ],
    "commands": ["langflow", "build-flow", "prompt-engineer", "release-notes"]
  }
}
